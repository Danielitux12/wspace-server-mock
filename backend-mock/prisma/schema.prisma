generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String        @id @default(uuid())
  name             String
  lastName         String        
  email            String        @unique
  phone            String        
  passwordHash     String        
  role             String        @default("USER") 
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  spaces           Space[]       @relation("OwnerSpaces")
  reservations     Reservation[] @relation("UserReservations")

  @@map("users")
}

model Space {
  id           String        @id @default(uuid())
  name         String
  type         String        
  description  String
  city         String
  neighborhood String        
  address      String        
  pricePerHour Float         
  capacity     Int
  photos       String[]      
  amenities    String[]      
  ownerId      String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  owner        User          @relation("OwnerSpaces", fields: [ownerId], references: [id])
  reservations Reservation[] @relation("SpaceReservations")

  @@map("spaces")
}

model Reservation {
  id              String   @id @default(uuid())
  userId          String
  spaceId         String
  reservationDate DateTime
  startTime       DateTime
  status          String   @default("PENDING") 
  user            User     @relation("UserReservations", fields: [userId], references: [id])
  space           Space    @relation("SpaceReservations", fields: [spaceId], references: [id])

  @@map("reservations")
}